---
// サイドバーコンポーネント（TagList + ArchiveNav）
import TagList from './TagList.astro';
import ArchiveNav from './ArchiveNav.astro';

interface Props {
  tags: { tag: string; count: number }[];
  years: number[];
  currentYear?: number;
}

const { tags, years, currentYear } = Astro.props;
---

<TagList tags={tags} />
<ArchiveNav years={years} currentYear={currentYear} />
