---
// タグ一覧サイドバーコンポーネント
interface Props {
  tags: { tag: string; count: number }[];
  currentTag?: string;
}

const { tags, currentTag } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="sidebar-section">
  <h2 class="sidebar-heading">タグ</h2>
  <ul class="tag-list">
    {tags.map(({ tag, count }) => (
      <li>
        <a
          href={`${base}tags/${encodeURIComponent(tag)}/`}
          class={tag === currentTag ? 'active' : undefined}
          aria-current={tag === currentTag ? 'page' : undefined}
        >
          #{tag}
          <span class="tag-count">{count}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .tag-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tag-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.83rem;
    color: var(--text);
    text-decoration: none;
    padding: 4px 8px;
    border-radius: var(--radius);
    transition: background 0.1s;
  }

  .tag-list a:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  .tag-list a.active {
    background: var(--accent-light);
    color: var(--accent);
    font-weight: 700;
  }

  .tag-count {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--border);
    padding: 1px 6px;
    border-radius: 20px;
  }
</style>
