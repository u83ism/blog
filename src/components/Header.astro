---
// サイトヘッダー（中央揃え・扉ページ的）
---

<header data-pagefind-ignore>
  <a class="site-title" href={import.meta.env.BASE_URL}>u83 <em>said so.</em></a>
  <p class="site-caption">since 2000</p>
</header>

<style>
  header {
    background: var(--bg);
    border-bottom: 1px solid var(--accent);
    padding: 32px 24px 24px;
    text-align: center;
  }

  .site-title {
    display: inline-block;
    font-family: var(--font-mincho);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .site-title em {
    font-style: normal;
    color: var(--accent);
  }

  .site-caption {
    margin-top: 8px;
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }

  @media (max-width: 600px) {
    header {
      padding: 24px 16px 18px;
    }

    .site-title {
      font-size: 1.5rem;
    }
  }
</style>
