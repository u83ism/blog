---
// 個別記事ページレイアウト（カラム集中型・サイドバーなし）
import Layout from './Layout.astro';
import { formatDateDisplay, buildPostUrl, resolveTitle } from '@/lib/posts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
}

const { post, prevPost, nextPost } = Astro.props;

const base = import.meta.env.BASE_URL;
const title = resolveTitle(post);
const dateDisplay = formatDateDisplay(post.data.date);
---

<Layout title={title} ogType="article">
  <article class="post-article">
    <header class="post-header">
      <time class="post-date" datetime={post.data.date.toISOString()}>{dateDisplay}</time>
      <h1 class="post-title">{title}</h1>
      {post.data.tags.length > 0 && (
        <ul class="post-tags" aria-label="タグ">
          {post.data.tags.map((tag) => (
            <li>
              <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <!-- 前後記事ナビゲーション -->
    <nav class="post-nav" aria-label="前後の記事">
      <div class="post-nav-prev">
        {nextPost && (
          <a href={buildPostUrl(base, nextPost.id)} data-astro-prefetch>
            ← {resolveTitle(nextPost)}
          </a>
        )}
      </div>
      <div class="post-nav-next">
        {prevPost && (
          <a href={buildPostUrl(base, prevPost.id)} data-astro-prefetch>
            {resolveTitle(prevPost)} →
          </a>
        )}
      </div>
    </nav>
  </article>
</Layout>

<style>
  .post-article {
    max-width: 800px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .post-header {
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--accent);
  }

  .post-date {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }

  .post-title {
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .post-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }

  .post-tags a {
    font-size: 0.72rem;
    color: var(--accent-dark);
    background: var(--accent-light);
    padding: 2px 10px;
    border-radius: 20px;
    text-decoration: none;
  }

  .post-tags a:hover {
    background: var(--accent);
    color: var(--white);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .post-nav a {
    font-size: 0.83rem;
    color: var(--accent);
    text-decoration: none;
    max-width: 45%;
    line-height: 1.6;
  }

  .post-nav a:hover {
    text-decoration: underline;
  }

  .post-nav-next {
    text-align: right;
  }
</style>
