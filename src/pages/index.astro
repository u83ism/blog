---
import '../styles/global.css';
import { getCollection } from 'astro:content';

// 最新のブログ記事を取得
const allBlogPosts = await getCollection('blog', ({ data }) => {
  return data.published === true;
});

const latestPosts = allBlogPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// 日付をフォーマットする関数
function formatDate(date: Date): string {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>ブログシステム - Astro</title>
	</head>
	<body class="bg-gray-50 text-gray-900">
		<div class="min-h-screen">
			<!-- ヘッダー -->
			<header class="bg-white shadow-sm border-b">
				<div class="max-w-4xl mx-auto px-4 py-6">
					<h1 class="text-3xl font-bold text-gray-900">My Blog</h1>
					<p class="text-gray-600 mt-2">Astro + TypeScript + Tailwind CSS で構築されたブログシステム</p>
					<nav class="mt-4">
						<a href="/blog" class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
							ブログ記事一覧を見る
						</a>
					</nav>
				</div>
			</header>

			<!-- メインコンテンツ -->
			<main class="max-w-4xl mx-auto px-4 py-8">
				<!-- ウェルカムセクション -->
				<section class="bg-white rounded-lg shadow-sm p-8 mb-8">
					<h2 class="text-2xl font-semibold text-gray-900 mb-4">ようこそ！</h2>
					<p class="text-gray-700 leading-relaxed mb-6">
						このブログシステムは、Astro、TypeScript、React、Tailwind CSSを使用して構築されています。
						静的サイト生成（SSG）により高速で、SEOに優れたブログを提供します。
					</p>
					<div class="flex flex-wrap gap-2">
						<span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">Astro</span>
						<span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-medium">TypeScript</span>
						<span class="px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-sm font-medium">React</span>
						<span class="px-3 py-1 bg-pink-100 text-pink-800 rounded-full text-sm font-medium">Tailwind CSS</span>
					</div>
				</section>

				<!-- 機能紹介 -->
				<section class="grid md:grid-cols-2 gap-6 mb-8">
					<div class="bg-white rounded-lg shadow-sm p-6">
						<h3 class="text-xl font-semibold text-gray-900 mb-3">高速なパフォーマンス</h3>
						<p class="text-gray-700">
							Astroの静的サイト生成により、超高速なページ読み込みを実現します。
						</p>
					</div>
					<div class="bg-white rounded-lg shadow-sm p-6">
						<h3 class="text-xl font-semibold text-gray-900 mb-3">SEO最適化</h3>
						<p class="text-gray-700">
							静的HTMLの生成により、検索エンジンに優しいサイト構造を提供します。
						</p>
					</div>
					<div class="bg-white rounded-lg shadow-sm p-6">
						<h3 class="text-xl font-semibold text-gray-900 mb-3">レスポンシブデザイン</h3>
						<p class="text-gray-700">
							Tailwind CSSにより、あらゆるデバイスで美しく表示されます。
						</p>
					</div>
					<div class="bg-white rounded-lg shadow-sm p-6">
						<h3 class="text-xl font-semibold text-gray-900 mb-3">型安全性</h3>
						<p class="text-gray-700">
							TypeScriptにより、開発時の型安全性とコード品質を保証します。
						</p>
					</div>
				</section>

				<!-- 最新記事 -->
				<section class="bg-white rounded-lg shadow-sm p-8">
					<div class="flex justify-between items-center mb-6">
						<h2 class="text-2xl font-semibold text-gray-900">最新記事</h2>
						<a href="/blog" class="text-blue-600 hover:text-blue-800 font-medium transition-colors">
							すべての記事を見る →
						</a>
					</div>
					<div class="space-y-6">
						{latestPosts.length > 0 ? (
							latestPosts.map((post) => (
								<article class="border-b border-gray-200 pb-6 last:border-b-0">
									<h3 class="text-xl font-semibold text-gray-900 mb-2">
										<a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
											{post.data.title}
										</a>
									</h3>
									<p class="text-gray-600 text-sm mb-3">{formatDate(post.data.date)}</p>
									<p class="text-gray-700 leading-relaxed mb-3">
										{post.data.description}
									</p>
									<div class="flex gap-2">
										{post.data.tags.map((tag) => (
											<span class="px-2 py-1 bg-gray-100 text-gray-700 rounded text-xs">{tag}</span>
										))}
									</div>
								</article>
							))
						) : (
							<p class="text-gray-500 text-center py-8">まだ記事がありません。</p>
						)}
					</div>
				</section>
			</main>

			<!-- フッター -->
			<footer class="bg-white border-t mt-12">
				<div class="max-w-4xl mx-auto px-4 py-6">
					<p class="text-center text-gray-600">
						© 2024 My Blog. Built with Astro, TypeScript, React & Tailwind CSS.
					</p>
				</div>
			</footer>
		</div>
	</body>
</html>
