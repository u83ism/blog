---
// ページネーション（2ページ目以降）
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostList from '@/components/PostList.astro';
import Pagination from '@/components/Pagination.astro';
import { sortPostsByDateDesc } from '@/lib/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const sorted = sortPostsByDateDesc(allPosts);
  const PAGE_SIZE = 20;
  const totalPages = Math.ceil(sorted.length / PAGE_SIZE);

  // page 1 は index.astro が担当するため 2 から開始
  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    return {
      params: { page: String(pageNum) },
      props: {
        posts: sorted.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE),
        pageNum,
        totalPages,
      },
    };
  });
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'posts'>>>;
  pageNum: number;
  totalPages: number;
}

const { posts, pageNum, totalPages } = Astro.props;
---

<Layout title={`記事一覧 ${pageNum}ページ目`}>
  <div class="container" style="padding-top: 32px; padding-bottom: 48px;">
    <h1 class="page-heading">記事一覧（{pageNum} / {totalPages} ページ）</h1>

    <PostList posts={posts} />

    <Pagination pageNum={pageNum} totalPages={totalPages} />
  </div>
</Layout>
