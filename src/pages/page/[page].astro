---
// ページネーション（2ページ目以降）
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostList from '@/components/PostList.astro';
import TagList from '@/components/TagList.astro';
import ArchiveNav from '@/components/ArchiveNav.astro';
import { sortPostsByDateDesc, collectTags, groupPostsByYear } from '@/lib/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const sorted = sortPostsByDateDesc(allPosts);
  const PAGE_SIZE = 20;
  const totalPages = Math.ceil(sorted.length / PAGE_SIZE);

  // page 1 は index.astro が担当するため 2 から開始
  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    return {
      params: { page: String(pageNum) },
      props: {
        posts: sorted.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE),
        pageNum,
        totalPages,
      },
    };
  });
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'posts'>>>;
  pageNum: number;
  totalPages: number;
}

const { posts, pageNum, totalPages } = Astro.props;

// サイドバー用データ
const allPosts = await getCollection('posts');
const tags = collectTags(allPosts);
const years = groupPostsByYear(allPosts).map(({ year }) => year);

const base = import.meta.env.BASE_URL;
---

<Layout title={`記事一覧 ${pageNum}ページ目`}>
  <Fragment slot="sidebar">
    <TagList tags={tags} />
    <ArchiveNav years={years} />
  </Fragment>

  <div class="container" style="padding-top: 32px; padding-bottom: 48px;">
    <h1 class="page-heading">記事一覧（{pageNum} / {totalPages} ページ）</h1>

    <PostList posts={posts} />

    <nav class="pagination" aria-label="ページナビゲーション">
      <div class="pagination-prev">
        {pageNum === 2
          ? <a href={`${base}`} data-astro-prefetch>← 前のページ</a>
          : <a href={`${base}page/${pageNum - 1}/`} data-astro-prefetch>← 前のページ</a>
        }
      </div>
      <span class="pagination-info">{pageNum} / {totalPages} ページ</span>
      <div class="pagination-next">
        {pageNum < totalPages && (
          <a href={`${base}page/${pageNum + 1}/`} data-astro-prefetch>次のページ →</a>
        )}
      </div>
    </nav>
  </div>
</Layout>

<style>
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .pagination-info {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .pagination-prev a,
  .pagination-next a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    transition: background 0.1s;
  }

  .pagination-prev a:hover,
  .pagination-next a:hover {
    background: var(--accent-light);
  }
</style>
