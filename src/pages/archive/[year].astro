---
// 年別アーカイブページ（月別グループ表示）
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostList from '@/components/PostList.astro';
import ArchiveNav from '@/components/ArchiveNav.astro';
import { groupPostsByYear, groupPostsByMonth } from '@/lib/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const yearGroups = groupPostsByYear(allPosts);

  return yearGroups.map(({ year, posts }) => ({
    params: { year: String(year) },
    props: { year, posts },
  }));
}

interface Props {
  year: number;
  posts: Awaited<ReturnType<typeof getCollection<'posts'>>>;
}

const { year, posts } = Astro.props;

// サイドバー用データ
const allPosts = await getCollection('posts');
const sortedYears = groupPostsByYear(allPosts).map(({ year: y }) => y);

// 月別グループ化
const monthGroups = groupPostsByMonth(posts);

const MONTH_NAMES = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
const base = import.meta.env.BASE_URL;
---

<Layout title={`${year}年のアーカイブ`}>
  <Fragment slot="sidebar">
    <ArchiveNav years={sortedYears} currentYear={year} />
  </Fragment>

  <div class="container" style="padding-top: 32px; padding-bottom: 48px;">
    <h1 class="page-heading">{year}年の記事（{posts.length}件）</h1>

    {monthGroups.map(({ month, posts: monthPosts }) => (
      <section class="month-section">
        <h2 class="month-heading">
          <a href={`${base}archive/${year}/${String(month).padStart(2, '0')}/`} data-astro-prefetch>
            {MONTH_NAMES[month - 1]}
          </a>
        </h2>
        <PostList posts={monthPosts} />
      </section>
    ))}
  </div>
</Layout>

<style>
  /* globalの.page-headingを上書き：年別アーカイブは余白を広めに */
  .page-heading {
    margin-bottom: 28px;
  }

  .month-section {
    margin-bottom: 32px;
  }

  .month-heading {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 10px;
    display: inline-block;
  }

  .month-heading a {
    color: var(--accent-dark);
    padding: 4px 10px;
    background: var(--accent-light);
    border-radius: var(--radius);
    text-decoration: none;
    display: inline-block;
    transition: background 0.1s, color 0.1s;
  }

  .month-heading a:hover {
    background: var(--accent);
    color: var(--white);
  }
</style>
