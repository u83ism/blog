---
// タグ別記事一覧ページ
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import PostList from '@/components/PostList.astro';
import TagList from '@/components/TagList.astro';
import { sortPostsByDateDesc, collectTags } from '@/lib/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  // 全タグを収集する
  const tagSet = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag);
    }
  }

  // タグごとに記事をフィルタリングしてページを生成する
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: sortPostsByDateDesc(allPosts.filter((p) => p.data.tags.includes(tag))),
    },
  }));
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection<'posts'>>>;
}

const { tag, posts } = Astro.props;

// サイドバー用データ
const allPosts = await getCollection('posts');
const tags = collectTags(allPosts);
---

<Layout title={`#${tag} の記事`}>
  <Fragment slot="sidebar">
    <TagList tags={tags} currentTag={tag} />
  </Fragment>

  <div class="container" style="padding-top: 32px; padding-bottom: 48px;">
    <h1 class="page-heading">
      <span class="tag-badge">#{tag}</span>
      <span class="post-count">（{posts.length}件）</span>
    </h1>

    <PostList posts={posts} />
  </div>
</Layout>

<style>
  /* globalの.page-headingを上書き：タグページ固有スタイル */
  .page-heading {
    border-bottom-width: 2px;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .tag-badge {
    color: var(--accent);
  }

  .post-count {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
  }
</style>
