---
// タグ一覧ページ
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ArchiveNav from '@/components/ArchiveNav.astro';
import { collectTags, groupPostsByYear } from '@/lib/posts';

const allPosts = await getCollection('posts');
const tags = collectTags(allPosts);
const years = groupPostsByYear(allPosts).map(({ year }) => year);

const base = import.meta.env.BASE_URL;
---

<Layout title="タグ一覧">
  <Fragment slot="sidebar">
    <ArchiveNav years={years} />
  </Fragment>

  <div class="container" style="padding-top: 32px; padding-bottom: 48px;">
    <h1 class="page-heading">タグ一覧</h1>

    {tags.length === 0 ? (
      <p class="empty">タグはまだありません。</p>
    ) : (
      <ul class="tag-grid">
        {tags.map(({ tag, count }) => (
          <li>
            <a href={`${base}tags/${encodeURIComponent(tag)}/`}>
              <span class="tag-name">#{tag}</span>
              <span class="tag-count">{count}件</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>

<style>
  .empty {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .tag-grid {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-grid a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 14px;
    text-decoration: none;
    transition: border-color 0.1s, background 0.1s;
  }

  .tag-grid a:hover {
    border-color: var(--accent);
    background: var(--accent-light);
  }

  .tag-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
  }

  .tag-count {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
</style>
